---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getHomeConfig, getQuestionEntries, getQuestionsBySlugs } from '../data/content';

const homeConfig = await getHomeConfig();
const featuredQuestions = await getQuestionsBySlugs(homeConfig.data.featuredQuestionSlugs);
const allQuestions = await getQuestionEntries();
const featuredQuestionIds = new Set(featuredQuestions.map((question) => question.id));
const nonFeaturedQuestions = allQuestions
  .filter((question) => !featuredQuestionIds.has(question.id))
  .sort((a, b) => {
    const aTime = a.data.publishedAt ? new Date(a.data.publishedAt).getTime() : 0;
    const bTime = b.data.publishedAt ? new Date(b.data.publishedAt).getTime() : 0;
    return bTime - aTime;
  });
const feedQuestions = [...featuredQuestions, ...nonFeaturedQuestions];
const heroFeatured = (await getQuestionsBySlugs([homeConfig.data.heroFeaturedSlug]))[0];
const editorialQuestions = await getQuestionsBySlugs(homeConfig.data.editorialPicks.map((item) => item.slug));
const editorialPicks = editorialQuestions.map((question, index) => ({
  label: homeConfig.data.editorialPicks[index]?.label ?? 'مختارات',
  title: question.data.title,
  href: `/${question.id}/`
}));

const communities = [
  {
    name: 'مجتمع التقنية',
    description: 'حوارات عن البرمجة، المنتجات، والاتجاهات الرقمية بلغة عربية واضحة.',
    members: '12k عضو'
  },
  {
    name: 'مجتمع التاريخ',
    description: 'أسئلة عميقة حول التاريخ الإسلامي والعالمي بعيداً عن التبسيط المخل.',
    members: '8.4k عضو'
  },
  {
    name: 'مجتمع العمل الحر',
    description: 'خبرات عملية للتسعير، بناء السمعة، وإدارة المشاريع مع العملاء.',
    members: '5.7k عضو'
  }
];

const proverbs = [
  {
    text: 'اطلب العلم من المهد إلى اللحد.',
    note: 'دعوة دائمة إلى أن المعرفة رحلة لا تتوقف.'
  },
  {
    text: 'درهم وقاية خير من قنطار علاج.',
    note: 'التدبير المبكر أوفر من إصلاح الخطأ بعد وقوعه.'
  },
  {
    text: 'الصبر مفتاح الفرج.',
    note: 'النتائج الكبيرة تحتاج نفساً طويلاً وثباتاً.'
  },
  {
    text: 'خير الكلام ما قل ودل.',
    note: 'القيمة ليست في كثرة الحديث بل في وضوح المعنى.'
  },
  {
    text: 'من جد وجد ومن زرع حصد.',
    note: 'العمل المتواصل هو الطريق الطبيعي للثمرة.'
  },
  {
    text: 'رب ضارة نافعة.',
    note: 'بعض التعثرات تفتح باباً لفهم أفضل أو فرصة أنضج.'
  },
  {
    text: 'لكل مقام مقال.',
    note: 'الحكمة في اختيار العبارة التي تناسب السياق.'
  },
  {
    text: 'يد واحدة لا تصفق.',
    note: 'التعاون ينجز ما تعجز عنه الجهود المنفردة.'
  },
  {
    text: 'ليس كل ما يلمع ذهباً.',
    note: 'المظهر وحده لا يكفي للحكم على القيمة الحقيقية.'
  }
];
---

<BaseLayout
  title="Sinwjim | منصة عربية للأسئلة والإجابات"
  description="نسخة MVP من منصة عربية للأسئلة والإجابات مستوحاة من Zhihu وQuora مع دعم كامل للعربية والموبايل."
>
  <div class="page-shell" id="top">
    <Header />

    <main>
      <section class="hero-section">
        <div class="hero-copy">
          <div class="hero-kicker-row">
            <p class="eyebrow">افتتاحية المنصة</p>
            <span class="hero-bulletin">عدد تجريبي - ربيع 2026</span>
          </div>
          <h1>مساحة عربية للأسئلة الذكية والإجابات التي تستحق أن تُحفَظ.</h1>
          <p class="hero-text">
            Sinwjim يجمع بين سرعة التصفح التي يحبها القراء ونَفَسٍ تحريري يفضّل الفكرة
            الواضحة، والسياق، والأصوات التي تكتب لتُفهَم لا لتُستهلك سريعاً.
          </p>

          <div class="hero-actions">
            <a class="cta-button" href="#feed">استكشف الإجابات</a>
            <a class="ghost-button" href="#spaces">استكشف المجتمعات</a>
          </div>

          <div class="hero-note">
            <strong>ماذا نعدك؟</strong>
            <p>
              أسئلة أقل ضجيجاً، إجابات أكثر عمقاً، وتجربة عربية واضحة على الهاتف
              والكمبيوتر من اليوم الأول.
            </p>
          </div>

          <div class="hero-stats" aria-label="Platform highlights">
            <div>
              <strong>+12k</strong>
              <span>قارئ أسبوعي</span>
            </div>
            <div>
              <strong>340</strong>
              <span>إجابة معمقة</span>
            </div>
            <div>
              <strong>27</strong>
              <span>مجتمعاً متخصصاً</span>
            </div>
          </div>
        </div>

        <a class="hero-panel hero-panel--link" href={`/${heroFeatured.id}/`} aria-label="Featured discussion preview">
          <div class="hero-panel__top">
            <span>نقاش اليوم</span>
            <span>يتصدر الآن</span>
          </div>
          <h2>{heroFeatured.data.title}</h2>
          <p>{heroFeatured.data.excerpt}</p>
          <div class="hero-panel__meta">
            <span>{heroFeatured.data.answers} إجابة</span>
            <span>{heroFeatured.data.stats[1]?.value} مشاهدة</span>
            <span>قراءة مميزة</span>
          </div>
        </a>
      </section>

      <section class="content-grid" id="feed">
        <div class="main-column">
          <SectionHeading
            title="إجابات مميزة في الصفحة الرئيسية"
            subtitle="الخلاصة اليومية"
          />

          <p class="question-list__intro">
            تبدأ القائمة بالمحتوى المختار للواجهة، ثم تُلحق به أحدث الأسئلة المنشورة في
            المنصة حتى لا تضيع الإضافات الجديدة خارج الصفحة الرئيسية.
          </p>

          <div class="question-list">
            {feedQuestions.map((question) => (
              <article class="question-card">
                <div class="question-card__meta">
                  <span class="question-category">{question.data.category}</span>
                  <span class="question-card__answers">{question.data.answers} إجابة</span>
                </div>
                <h3><a href={`/${question.id}/`}>{question.data.title}</a></h3>
                <p>{question.data.excerpt}</p>
                <div class="question-card__footer">
                  <div class="question-card__author">
                    <strong>{question.data.author}</strong>
                    <span>{question.data.role}</span>
                  </div>
                  <div class="question-card__actions">
                    <div class="vote-chip">{question.data.votes} تصويت</div>
                    <a class="question-card__readmore" href={`/${question.id}/`}>اقرأ الإجابة</a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>

        <aside class="sidebar-column">
          <section class="sidebar-card editorial-card">
            <p class="sidebar-card__eyebrow">مختارات التحرير</p>
            <h3>ثلاث محطات سريعة لبدء القراءة اليوم</h3>
            <div class="editorial-picks-list">
              {editorialPicks.map((pick) => (
                <a class="editorial-pick" href={pick.href}>
                  <span class="editorial-pick__label">{pick.label}</span>
                  <strong>{pick.title}</strong>
                </a>
              ))}
            </div>
          </section>

          <section class="sidebar-card" id="spaces">
            <SectionHeading
              title="مجتمعات نشطة"
              subtitle="مساحات متخصصة"
              accent="gold"
            />
            <div class="community-list">
              {communities.map((community) => (
                <article class="community-item">
                  <div>
                    <h3>{community.name}</h3>
                    <p>{community.description}</p>
                  </div>
                  <span>{community.members}</span>
                </article>
              ))}
            </div>
          </section>
        </aside>
      </section>

      <section class="proverbs-section" id="voices" data-proverbs-section>
        <SectionHeading
          title="أمثال عربية"
          subtitle="حكمة متجددة"
          accent="rose"
        />
        <div class="proverbs-grid" data-proverbs-grid>
          {proverbs.map((proverb, index) => (
            <article class="proverb-card" data-proverb-card data-group={Math.floor(index / 3)}>
              <span class="proverb-badge">مثل مأثور</span>
              <h3>{proverb.text}</h3>
              <p class="proverb-note">{proverb.note}</p>
            </article>
          ))}
        </div>
      </section>

      <script is:inline>
        (() => {
          const section = document.querySelector('[data-proverbs-section]');
          if (!section) return;

          const cards = Array.from(section.querySelectorAll('[data-proverb-card]'));
          if (cards.length === 0) return;

          const totalGroups = cards.reduce((max, card) => {
            const group = Number(card.getAttribute('data-group') || '0');
            return Math.max(max, group);
          }, 0) + 1;

          let activeGroup = 0;

          const renderGroup = () => {
            cards.forEach((card) => {
              const group = Number(card.getAttribute('data-group') || '0');
              const isActive = group === activeGroup;
              card.toggleAttribute('hidden', !isActive);
            });
          };

          renderGroup();

          if (totalGroups > 1) {
            window.setInterval(() => {
              activeGroup = (activeGroup + 1) % totalGroups;
              renderGroup();
            }, 10000);
          }
        })();
      </script>
    </main>
  </div>
</BaseLayout>
