---
import { render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import { getQuestionsBySlugs } from '../data/content';

interface Props {
  question: CollectionEntry<'questions'>;
  metaLabel?: string;
  answerLabel?: string;
}

const {
  question,
  metaLabel = 'سؤال تحليلي طويل',
  answerLabel = 'إجابة مميزة'
} = Astro.props;

const relatedQuestions = question.data.relatedSlugs.length
  ? await getQuestionsBySlugs(question.data.relatedSlugs)
  : [];
const { Content } = await render(question);
const pageTitle = question.data.pageTitle ?? `Sinwjim | ${question.data.title}`;
const pageDescription = question.data.pageDescription ?? question.data.excerpt;
const coverImage = question.data.coverImage;
const coverImageAlt = question.data.coverImageAlt ?? question.data.title;
const lead = question.data.lead ?? question.data.excerpt;
const stats = question.data.stats.length
  ? question.data.stats
  : [
      { value: String(question.data.answers), label: 'إجابة' },
      { value: question.data.votes, label: 'تصويت' }
    ];
const whyNowTitle = question.data.whyNowTitle ?? 'لماذا يهم هذا السؤال؟';
const whyNowText =
  question.data.whyNowText ??
  'هذا السؤال منشور حديثاً على Sinwjim، ويمكنك العودة لاحقاً لقراءة التحديثات والتفاصيل المرتبطة به.';
const topics = question.data.topics;
const answerTitle = question.data.answerTitle ?? 'إجابة منشورة';
const summary = question.data.summary;
const isLiveClockQuestion = question.id === '2-كم-الساعة-الآن';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="page-shell question-page-shell">
    <Header />

    <main class="question-page">
      <section class="question-hero">
        <div class="question-hero__main">
          <div class="question-hero__meta">
            <span class="question-hero__category">{question.data.category}</span>
            <span>{metaLabel}</span>
          </div>
          <h1>{question.data.title}</h1>
          <p class="question-hero__lead">{lead}</p>
          {
            coverImage && (
              <figure class="question-hero__figure">
                <img src={coverImage} alt={coverImageAlt} loading="eager" />
              </figure>
            )
          }
          {
            isLiveClockQuestion && (
              <section class="live-clock-card" aria-label="الوقت الحالي" data-live-clock>
                <div class="live-clock-card__copy">
                  <p class="live-clock-card__eyebrow">الوقت الآن</p>
                  <h2>ساعة حية بحسب توقيت متصفحك</h2>
                  <p>تتحدث هذه الساعة مباشرة اعتماداً على الوقت المحلي الحالي في متصفحك والمنطقة الزمنية المضبوطة على جهازك.</p>
                </div>
                <div class="live-clock-card__display" aria-live="polite">
                  <div class="live-clock-card__digital">
                    <span class="live-clock-card__time" data-clock-time>--:--:--</span>
                    <span class="live-clock-card__meridiem" data-clock-meridiem>--</span>
                  </div>
                  <div class="live-clock-card__meta">
                    <span data-clock-date>جاري تحديد التاريخ...</span>
                    <span data-clock-zone>جاري تحديد المنطقة الزمنية...</span>
                  </div>
                </div>
                <div class="live-clock-face" aria-hidden="true">
                  <div class="live-clock-face__ring"></div>
                  <div class="live-clock-face__marker live-clock-face__marker--12"></div>
                  <div class="live-clock-face__marker live-clock-face__marker--3"></div>
                  <div class="live-clock-face__marker live-clock-face__marker--6"></div>
                  <div class="live-clock-face__marker live-clock-face__marker--9"></div>
                  <div class="live-clock-face__hand live-clock-face__hand--hour" data-clock-hour-hand></div>
                  <div class="live-clock-face__hand live-clock-face__hand--minute" data-clock-minute-hand></div>
                  <div class="live-clock-face__hand live-clock-face__hand--second" data-clock-second-hand></div>
                  <div class="live-clock-face__center"></div>
                </div>
              </section>
            )
          }
          <div class="question-hero__stats" aria-label="Question activity">
            {stats.map((stat) => (
              <div>
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </div>
            ))}
          </div>
        </div>

        <aside class="question-sidebar-card">
          <p class="question-sidebar-card__eyebrow">عن هذا السؤال</p>
          <h2>{whyNowTitle}</h2>
          <p>{whyNowText}</p>
          {
            topics.length > 0 && (
              <div class="question-topic-list">
                {topics.map((topic) => <span>{topic}</span>)}
              </div>
            )
          }
        </aside>
      </section>

      <section class="question-detail-grid">
        <article class="answer-card">
          <div class="answer-card__header">
            <div>
              <p class="answer-card__eyebrow">{answerLabel}</p>
              <h2>{answerTitle}</h2>
            </div>
            <div class="answer-author">
              <strong>{question.data.author}</strong>
              <span>{question.data.role}</span>
            </div>
          </div>

          <div class="answer-body">
            <Content />
          </div>
        </article>

        <aside class="question-sidebar">
          {
            summary.length > 0 && (
              <section class="question-sidebar-card">
                <p class="question-sidebar-card__eyebrow">ملخص سريع</p>
                <ul class="question-summary-list">
                  {summary.map((item) => <li>{item}</li>)}
                </ul>
              </section>
            )
          }

          <section class="question-sidebar-card">
            <p class="question-sidebar-card__eyebrow">انتقال سريع</p>
            <div class="question-sidebar-actions">
              <a class="ghost-button" href="/">العودة إلى الرئيسية</a>
              <a class="cta-button" href="/#feed">استكشف أسئلة أخرى</a>
            </div>
          </section>
        </aside>
      </section>

      {
        relatedQuestions.length > 0 && (
          <section class="related-questions-section">
            <div class="related-questions-section__heading">
              <p>أسئلة مرتبطة</p>
              <h2>واصل القراءة في الموضوعات المتقاطعة</h2>
            </div>
            <div class="related-questions-grid">
              {relatedQuestions.map((item) => (
                <a class="related-question-card" href={`/${item.id}/`}>
                  <span class="related-question-card__category">{item.data.category}</span>
                  <h3>{item.data.title}</h3>
                </a>
              ))}
            </div>
          </section>
        )
      }
    </main>
  </div>

  {
    isLiveClockQuestion && (
      <script is:inline>
        (() => {
          const root = document.querySelector('[data-live-clock]');
          if (!root) return;

          const timeEl = root.querySelector('[data-clock-time]');
          const meridiemEl = root.querySelector('[data-clock-meridiem]');
          const dateEl = root.querySelector('[data-clock-date]');
          const zoneEl = root.querySelector('[data-clock-zone]');
          const hourHand = root.querySelector('[data-clock-hour-hand]');
          const minuteHand = root.querySelector('[data-clock-minute-hand]');
          const secondHand = root.querySelector('[data-clock-second-hand]');

          const timeFormatter = new Intl.DateTimeFormat('ar', {
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit',
            hour12: true
          });

          const dateFormatter = new Intl.DateTimeFormat('ar', {
            weekday: 'long',
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          });

          const updateClock = () => {
            const now = new Date();
            const parts = timeFormatter.formatToParts(now);
            const timeValue = parts
              .filter((part) => part.type === 'hour' || part.type === 'minute' || part.type === 'second' || part.type === 'literal')
              .map((part) => part.value)
              .join('')
              .trim();
            const dayPeriod = parts.find((part) => part.type === 'dayPeriod')?.value ?? '';
            const timeZone = Intl.DateTimeFormat().resolvedOptions().timeZone;

            if (timeEl) timeEl.textContent = timeValue;
            if (meridiemEl) meridiemEl.textContent = dayPeriod;
            if (dateEl) dateEl.textContent = dateFormatter.format(now);
            if (zoneEl) zoneEl.textContent = `المنطقة الزمنية: ${timeZone}`;

            const seconds = now.getSeconds() + now.getMilliseconds() / 1000;
            const minutes = now.getMinutes() + seconds / 60;
            const hours = (now.getHours() % 12) + minutes / 60;

            if (hourHand) hourHand.style.setProperty('--rotation', `${hours * 30}deg`);
            if (minuteHand) minuteHand.style.setProperty('--rotation', `${minutes * 6}deg`);
            if (secondHand) secondHand.style.setProperty('--rotation', `${seconds * 6}deg`);
          };

          updateClock();
          window.setInterval(updateClock, 1000);
        })();
      </script>
    )
  }
</BaseLayout>
