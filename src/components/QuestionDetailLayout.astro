            const isAppleCpu = (cpuValue) => cpuValue.startsWith('apple-');
            const syncGpuState = () => {
              if (!gpuSelect) return;
              const cpuValue = cpuSelect?.value ?? '';
              const appleCpuSelected = isAppleCpu(cpuValue);
              gpuSelect.disabled = appleCpuSelected;
              gpuSelect.classList.toggle('model-hardware-form__control--disabled', appleCpuSelected);
              if (appleCpuSelected) {
                gpuSelect.value = 'apple-integrated';
              } else if (gpuSelect.value === 'apple-integrated') {
                gpuSelect.value = '';
              }
            };

            const renderResults = (items, cpuValue, gpuValue, ramValue) => {
              if (!results) return;
              const cpuLabel = cpuLabels[cpuValue] ?? 'غير معروف';
              const gpuLabel = gpuLabels[gpuValue] ?? 'غير معروف';
              if (!items.length) {
                results.innerHTML = `
                  <div class="model-hardware-results__summary">
                    <strong>النتيجة الحالية</strong>
                    <span>المعالج: ${cpuLabel} • البطاقة الرسومية: ${gpuLabel} • الذاكرة: ${ramValue} GiB</span>
                  </div>
                  <p class="model-hardware-results__empty">لا تظهر في هذا التقدير نماذج كبيرة مريحة لهذا المستوى. جرّب البدء بنماذج أصغر جداً أو زيادة الذاكرة أو استخدام بطاقة رسومية أقوى إذا كان ذلك ممكناً.</p>
                `;
                return;
              }

              const itemsMarkup = items.map((item) => `
                <article class="model-hardware-results__item">
                  <div>
                    <h3>${item.name}</h3>
                    <p>${item.note}</p>
                  </div>
                  <div class="model-hardware-results__meta">
                    <span>الحد الأدنى التقديري: ${item.minRam} GiB</span>
                    <span>${item.availability}</span>
                  </div>
                </article>
              `).join('');

              results.innerHTML = `
                <div class="model-hardware-results__summary">
                  <strong>النتيجة الحالية</strong>
                  <span>المعالج: ${cpuLabel} • البطاقة الرسومية: ${gpuLabel} • الذاكرة: ${ramValue} GiB</span>
                </div>
                <div class="model-hardware-results__list">${itemsMarkup}</div>
              `;
            };

            syncGpuState();
            cpuSelect?.addEventListener('change', () => {
              syncGpuState();
            });

            form?.addEventListener('submit', (event) => {
              event.preventDefault();
              const cpuValue = cpuSelect?.value ?? '';
              const gpuValue = gpuSelect?.value ?? '';
              const ramValue = Number.parseInt((ramInput?.value ?? '').trim(), 10);
              const effectiveGpuValue = isAppleCpu(cpuValue) ? 'apple-integrated' : gpuValue;

              if (!cpuValue || !effectiveGpuValue || !Number.isFinite(ramValue) || ramValue <= 0) {
                if (results) {
                  results.innerHTML = '<p class="model-hardware-results__empty">يرجى اختيار المعالج والبطاقة الرسومية وإدخال رقم صحيح للذاكرة بالـ GiB قبل عرض النتيجة.</p>';
                }
                return;
              }

              const matchedModels = modelCatalog.filter((model) => {
                return model.minRam <= ramValue && model.cpuTiers.includes(cpuValue) && model.gpuTiers.includes(effectiveGpuValue);
              });
              renderResults(matchedModels, cpuValue, effectiveGpuValue, ramValue);
            });
          }
