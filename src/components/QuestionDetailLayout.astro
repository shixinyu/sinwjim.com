---
import { render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import { getQuestionsBySlugs } from '../data/content';
import { middleEastReligiousHolidays } from '../data/middleEastReligiousHolidays';

interface Props {
  question: CollectionEntry<'questions'>;
  metaLabel?: string;
  answerLabel?: string;
}

const {
  question,
  metaLabel = 'سؤال تحليلي طويل',
  answerLabel = 'إجابة مميزة'
} = Astro.props;

const relatedQuestions = question.data.relatedSlugs.length
  ? await getQuestionsBySlugs(question.data.relatedSlugs)
  : [];
const { Content } = await render(question);
const pageTitle = question.data.pageTitle ?? `Sinwjim | ${question.data.title}`;
const pageDescription = question.data.pageDescription ?? question.data.excerpt;
const coverImage = question.data.coverImage;
const coverImageAlt = question.data.coverImageAlt ?? question.data.title;
const lead = question.data.lead ?? question.data.excerpt;
const stats = question.data.stats.length
  ? question.data.stats
  : [
      { value: String(question.data.answers), label: 'إجابة' },
      { value: question.data.votes, label: 'تصويت' }
    ];
const whyNowTitle = question.data.whyNowTitle ?? 'لماذا يهم هذا السؤال؟';
const whyNowText =
  question.data.whyNowText ??
  'هذا السؤال منشور حديثاً على Sinwjim، ويمكنك العودة لاحقاً لقراءة التحديثات والتفاصيل المرتبطة به.';
const topics = question.data.topics;
const answerTitle = question.data.answerTitle ?? 'إجابة منشورة';
const summary = question.data.summary;
const isLiveClockQuestion = question.id === '2-كم-الساعة-الآن';
const isHolidayQuestion = question.id === '7-ما-هو-العيد-اليوم';
const holidayEntriesPayload = JSON.stringify(middleEastReligiousHolidays);
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="page-shell question-page-shell">
    <Header />

    <main class="question-page">
      <section class="question-hero">
        <div class="question-hero__main">
          <div class="question-hero__meta">
            <span class="question-hero__category">{question.data.category}</span>
            <span>{metaLabel}</span>
          </div>
          <h1>{question.data.title}</h1>
          <p class="question-hero__lead">{lead}</p>
          {
            coverImage && (
              <figure class="question-hero__figure">
                <img src={coverImage} alt={coverImageAlt} loading="eager" />
              </figure>
            )
          }
          {
            isLiveClockQuestion && (
              <section class="live-clock-card" aria-label="الوقت الحالي" data-live-clock>
                <div class="live-clock-card__copy">
                  <p class="live-clock-card__eyebrow">الوقت الآن</p>
                  <h2>ساعة حية بحسب توقيت متصفحك</h2>
                  <p>تتحدث هذه الساعة مباشرة اعتماداً على الوقت المحلي الحالي في متصفحك والمنطقة الزمنية المضبوطة على جهازك.</p>
                </div>
                <div class="live-clock-card__display" aria-live="polite">
                  <div class="live-clock-card__digital">
                    <span class="live-clock-card__time" data-clock-time>--:--:--</span>
                    <span class="live-clock-card__meridiem" data-clock-meridiem>--</span>
                  </div>
                  <div class="live-clock-card__meta">
                    <span data-clock-date>جاري تحديد التاريخ...</span>
                    <span data-clock-zone>جاري تحديد المنطقة الزمنية...</span>
                  </div>
                </div>
                <div class="live-clock-face" aria-hidden="true">
                  <div class="live-clock-face__ring"></div>
                  <div class="live-clock-face__marker live-clock-face__marker--12"></div>
                  <div class="live-clock-face__marker live-clock-face__marker--3"></div>
                  <div class="live-clock-face__marker live-clock-face__marker--6"></div>
                  <div class="live-clock-face__marker live-clock-face__marker--9"></div>
                  <div class="live-clock-face__hand live-clock-face__hand--hour" data-clock-hour-hand></div>
                  <div class="live-clock-face__hand live-clock-face__hand--minute" data-clock-minute-hand></div>
                  <div class="live-clock-face__hand live-clock-face__hand--second" data-clock-second-hand></div>
                  <div class="live-clock-face__center"></div>
                </div>
              </section>
            )
          }
          {
            isHolidayQuestion && (
              <section class="holiday-calendar-card" aria-label="تقويم الأعياد الدينية" data-holiday-calendar>
                <div class="holiday-calendar-card__header">
                  <div>
                    <p class="holiday-calendar-card__eyebrow">تقويم الأعياد</p>
                    <h2>ما هو العيد اليوم؟</h2>
                    <p>يعرض هذا التقويم الشهر الحالي بحسب تاريخ متصفحك، مع إبراز أبرز الأعياد الدينية الشائعة في دول الشرق الأوسط.</p>
                  </div>
                  <div class="holiday-calendar-card__today" data-holiday-today>
                    <strong data-holiday-today-label>جاري التحقق من عيد اليوم...</strong>
                    <span data-holiday-today-meta>سيظهر هنا اسم المناسبة والدول المرتبطة بها عند توفرها.</span>
                  </div>
                </div>
                <div class="holiday-calendar-card__toolbar">
                  <button type="button" class="holiday-calendar-card__nav" data-holiday-prev aria-label="الشهر السابق">&#8592;</button>
                  <div class="holiday-calendar-card__month">
                    <strong data-holiday-month-label>الشهر الحالي</strong>
                    <span>بحسب تاريخ المتصفح</span>
                  </div>
                  <button type="button" class="holiday-calendar-card__nav" data-holiday-next aria-label="الشهر التالي">&#8594;</button>
                </div>
                <div class="holiday-calendar-card__filters">
                  <label class="holiday-calendar-card__filter">
                    <span>تصفية حسب الدولة</span>
                    <select data-holiday-country>
                      <option value="">كل الدول والمناطق</option>
                    </select>
                  </label>
                </div>
                <div class="holiday-calendar-card__weekdays" aria-hidden="true">
                  <span>الأحد</span>
                  <span>الاثنين</span>
                  <span>الثلاثاء</span>
                  <span>الأربعاء</span>
                  <span>الخميس</span>
                  <span>الجمعة</span>
                  <span>السبت</span>
                </div>
                <div class="holiday-calendar-card__grid" data-holiday-grid></div>
                <div class="holiday-calendar-card__legend">
                  <span><i class="holiday-calendar-card__dot holiday-calendar-card__dot--today"></i> اليوم الحالي</span>
                  <span><i class="holiday-calendar-card__dot holiday-calendar-card__dot--islamic"></i> مناسبة إسلامية</span>
                  <span><i class="holiday-calendar-card__dot holiday-calendar-card__dot--christian"></i> مناسبة مسيحية</span>
                </div>
              </section>
            )
          }
          <div class="question-hero__stats" aria-label="Question activity">
            {stats.map((stat) => (
              <div>
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </div>
            ))}
          </div>
        </div>

        <aside class="question-sidebar-card">
          <p class="question-sidebar-card__eyebrow">عن هذا السؤال</p>
          <h2>{whyNowTitle}</h2>
          <p>{whyNowText}</p>
          {
            topics.length > 0 && (
              <div class="question-topic-list">
                {topics.map((topic) => <span>{topic}</span>)}
              </div>
            )
          }
        </aside>
      </section>

      <section class="question-detail-grid">
        <article class="answer-card">
          <div class="answer-card__header">
            <div>
              <p class="answer-card__eyebrow">{answerLabel}</p>
              <h2>{answerTitle}</h2>
            </div>
            <div class="answer-author">
              <strong>{question.data.author}</strong>
              <span>{question.data.role}</span>
            </div>
          </div>

          <div class="answer-body">
            <Content />
          </div>
        </article>

        <aside class="question-sidebar">
          {
            summary.length > 0 && (
              <section class="question-sidebar-card">
                <p class="question-sidebar-card__eyebrow">ملخص سريع</p>
                <ul class="question-summary-list">
                  {summary.map((item) => <li>{item}</li>)}
                </ul>
              </section>
            )
          }

          <section class="question-sidebar-card">
            <p class="question-sidebar-card__eyebrow">انتقال سريع</p>
            <div class="question-sidebar-actions">
              <a class="ghost-button" href="/">العودة إلى الرئيسية</a>
              <a class="cta-button" href="/#feed">استكشف أسئلة أخرى</a>
            </div>
          </section>
        </aside>
      </section>

      {
        relatedQuestions.length > 0 && (
          <section class="related-questions-section">
            <div class="related-questions-section__heading">
              <p>أسئلة مرتبطة</p>
              <h2>واصل القراءة في الموضوعات المتقاطعة</h2>
            </div>
            <div class="related-questions-grid">
              {relatedQuestions.map((item) => (
                <a class="related-question-card" href={`/${item.id}/`}>
                  <span class="related-question-card__category">{item.data.category}</span>
                  <h3>{item.data.title}</h3>
                </a>
              ))}
            </div>
          </section>
        )
      }
    </main>
  </div>

  {
    (isLiveClockQuestion || isHolidayQuestion) && (
      <script is:inline define:vars={{ holidayEntriesPayload }}>
        (() => {
          const liveClockRoot = document.querySelector('[data-live-clock]');
          if (liveClockRoot) {
            const timeEl = liveClockRoot.querySelector('[data-clock-time]');
            const meridiemEl = liveClockRoot.querySelector('[data-clock-meridiem]');
            const dateEl = liveClockRoot.querySelector('[data-clock-date]');
            const zoneEl = liveClockRoot.querySelector('[data-clock-zone]');
            const hourHand = liveClockRoot.querySelector('[data-clock-hour-hand]');
            const minuteHand = liveClockRoot.querySelector('[data-clock-minute-hand]');
            const secondHand = liveClockRoot.querySelector('[data-clock-second-hand]');

            const timeFormatter = new Intl.DateTimeFormat('ar', {
              hour: '2-digit',
              minute: '2-digit',
              second: '2-digit',
              hour12: true
            });

            const dateFormatter = new Intl.DateTimeFormat('ar', {
              weekday: 'long',
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            });

            const updateClock = () => {
              const now = new Date();
              const parts = timeFormatter.formatToParts(now);
              const timeValue = parts
                .filter((part) => part.type === 'hour' || part.type === 'minute' || part.type === 'second' || part.type === 'literal')
                .map((part) => part.value)
                .join('')
                .trim();
              const dayPeriod = parts.find((part) => part.type === 'dayPeriod')?.value ?? '';
              const timeZone = Intl.DateTimeFormat().resolvedOptions().timeZone;

              if (timeEl) timeEl.textContent = timeValue;
              if (meridiemEl) meridiemEl.textContent = dayPeriod;
              if (dateEl) dateEl.textContent = dateFormatter.format(now);
              if (zoneEl) zoneEl.textContent = `المنطقة الزمنية: ${timeZone}`;

              const seconds = now.getSeconds() + now.getMilliseconds() / 1000;
              const minutes = now.getMinutes() + seconds / 60;
              const hours = (now.getHours() % 12) + minutes / 60;

              if (hourHand) hourHand.style.setProperty('--rotation', `${hours * 30}deg`);
              if (minuteHand) minuteHand.style.setProperty('--rotation', `${minutes * 6}deg`);
              if (secondHand) secondHand.style.setProperty('--rotation', `${seconds * 6}deg`);
            };

            updateClock();
            window.setInterval(updateClock, 1000);
          }

          const calendarRoot = document.querySelector('[data-holiday-calendar]');
          if (calendarRoot) {
            const monthLabel = calendarRoot.querySelector('[data-holiday-month-label]');
            const grid = calendarRoot.querySelector('[data-holiday-grid]');
            const todayLabel = calendarRoot.querySelector('[data-holiday-today-label]');
            const todayMeta = calendarRoot.querySelector('[data-holiday-today-meta]');
            const prevButton = calendarRoot.querySelector('[data-holiday-prev]');
            const nextButton = calendarRoot.querySelector('[data-holiday-next]');
            const countrySelect = calendarRoot.querySelector('[data-holiday-country]');
            const monthFormatter = new Intl.DateTimeFormat('ar', { month: 'long', year: 'numeric' });
            const dayFormatter = new Intl.DateTimeFormat('ar', { day: 'numeric' });
            const fullDateFormatter = new Intl.DateTimeFormat('ar', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
            const holidays = JSON.parse(holidayEntriesPayload);
            const today = new Date();
            const todayKey = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
            let activeMonth = new Date(today.getFullYear(), today.getMonth(), 1);
            let activeCountry = '';

            const allCountries = [...new Set(holidays.flatMap((entry) => entry.countries))].sort((a, b) => a.localeCompare(b, 'ar'));
            if (countrySelect) {
              allCountries.forEach((country) => {
                const option = document.createElement('option');
                option.value = country;
                option.textContent = country;
                countrySelect.appendChild(option);
              });
            }

            const getFilteredHolidays = () => {
              if (!activeCountry) return holidays;
              return holidays.filter((entry) => entry.countries.includes(activeCountry));
            };

            const updateTodayCard = () => {
              const todayEntries = getFilteredHolidays().filter((entry) => entry.date === todayKey);
              if (!todayLabel || !todayMeta) return;
              if (!todayEntries.length) {
                const suffix = activeCountry ? ` في ${activeCountry}` : '';
                todayLabel.textContent = `لا يظهر عيد ديني مسجل${suffix} في بيانات اليوم الحالي`;
                todayMeta.textContent = `تاريخ اليوم: ${fullDateFormatter.format(today)}`;
                return;
              }

              todayLabel.textContent = todayEntries.map((entry) => entry.name).join(' • ');
              todayMeta.textContent = todayEntries
                .map((entry) => `${entry.countries.join('، ')}`)
                .join(' | ');
            };

            const renderMonth = () => {
              if (!grid || !monthLabel) return;
              const year = activeMonth.getFullYear();
              const month = activeMonth.getMonth();
              const firstDay = new Date(year, month, 1);
              const daysInMonth = new Date(year, month + 1, 0).getDate();
              const leading = firstDay.getDay();
              const filteredHolidays = getFilteredHolidays();
              const groupByDate = new Map();

              filteredHolidays.forEach((entry) => {
                if (!groupByDate.has(entry.date)) {
                  groupByDate.set(entry.date, []);
                }
                groupByDate.get(entry.date).push(entry);
              });

              monthLabel.textContent = monthFormatter.format(activeMonth);
              grid.innerHTML = '';

              for (let i = 0; i < leading; i += 1) {
                const filler = document.createElement('div');
                filler.className = 'holiday-calendar-card__cell holiday-calendar-card__cell--empty';
                grid.appendChild(filler);
              }

              for (let day = 1; day <= daysInMonth; day += 1) {
                const date = new Date(year, month, day);
                const key = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                const dayEntries = groupByDate.get(key) ?? [];
                const cell = document.createElement('article');
                const traditions = [...new Set(dayEntries.map((entry) => entry.tradition))];
                cell.className = 'holiday-calendar-card__cell';
                if (key === todayKey) cell.classList.add('holiday-calendar-card__cell--today');
                if (traditions.includes('islamic')) cell.classList.add('holiday-calendar-card__cell--islamic');
                if (traditions.includes('christian')) cell.classList.add('holiday-calendar-card__cell--christian');

                const dayNumber = document.createElement('strong');
                dayNumber.className = 'holiday-calendar-card__day';
                dayNumber.textContent = dayFormatter.format(date);
                cell.appendChild(dayNumber);

                if (dayEntries.length) {
                  dayEntries.forEach((entry) => {
                    const item = document.createElement('div');
                    item.className = `holiday-calendar-card__event holiday-calendar-card__event--${entry.tradition}`;

                    const title = document.createElement('span');
                    title.className = 'holiday-calendar-card__event-name';
                    title.textContent = entry.name;

                    const meta = document.createElement('small');
                    meta.className = 'holiday-calendar-card__event-meta';
                    meta.textContent = entry.countries.join('، ');

                    item.appendChild(title);
                    item.appendChild(meta);
                    cell.appendChild(item);
                  });
                } else {
                  const empty = document.createElement('span');
                  empty.className = 'holiday-calendar-card__empty-label';
                  empty.textContent = '—';
                  cell.appendChild(empty);
                }

                grid.appendChild(cell);
              }
            };

            const refreshCalendar = () => {
              updateTodayCard();
              renderMonth();
            };

            refreshCalendar();

            prevButton?.addEventListener('click', () => {
              activeMonth = new Date(activeMonth.getFullYear(), activeMonth.getMonth() - 1, 1);
              renderMonth();
            });

            nextButton?.addEventListener('click', () => {
              activeMonth = new Date(activeMonth.getFullYear(), activeMonth.getMonth() + 1, 1);
              renderMonth();
            });

            countrySelect?.addEventListener('change', (event) => {
              activeCountry = event.currentTarget.value;
              refreshCalendar();
            });
          }
        })();
      </script>
    )
  }
</BaseLayout>
