---
import '../styles/global.css';
import '../styles/question-detail.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  prevUrl?: string;
  nextUrl?: string;
}

const {
  title = 'Sinwjim | منصة عربية للأسئلة والمعرفة',
  description = 'منصة عربية مستوحاة من Zhihu وQuora لمشاركة المعرفة والإجابات العميقة.',
  canonical,
  prevUrl,
  nextUrl,
} = Astro.props;
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2e2c76" />
    <meta name="generator" content={Astro.generator} />
    {canonical && <link rel="canonical" href={canonical} />}
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
    <link rel="icon" type="image/x-icon" href="/sinwjim.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;500;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-W56DMR7Y2T"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(...args) { window.dataLayer.push(args); }
      gtag('js', new Date());
      gtag('config', 'G-W56DMR7Y2T');
    </script>
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <footer class="site-footer">
      <p>جميع الحقوق محفوظة لـ Sinwjim © 2026</p>
    </footer>
  </body>
</html>
